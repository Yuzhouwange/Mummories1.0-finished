# 聊天室数据库配置
# 复制此文件为 .env 并修改为你自己的配置

# 数据库配置 (与 Mummories 共用同一个 MySQL 实例)
DB_HOST=db
DB_NAME=chat
DB_USER=root
DB_PASS=your_secure_password_here
DB_PASSWORD=your_secure_password_here

# 应用配置
APP_NAME=Mummories
APP_URL=http://localhost:8080/chat

# 安全设置
TRUSTED_PROXIES=

# 管理员 API Key
HOMEPAGE_API_KEY=your_api_key_here
