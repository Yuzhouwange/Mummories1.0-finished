# Mummories 个人博客 - 环境配置
# 复制此文件为 .env 并修改为你自己的配置

# 数据库配置
DB_HOST=db
DB_NAME=mummories
DB_USER=root
DB_PASSWORD=your_secure_password_here

# 应用配置
APP_NAME=Mummories
APP_URL=http://localhost:8080

# 端口配置
HTTP_PORT=8080
PHPMYADMIN_PORT=9888

# 管理员 API Key (用于后台管理登录，请修改为你自己的密钥)
HOMEPAGE_API_KEY=your_api_key_here
